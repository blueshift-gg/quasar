{
  "name": "@blueshift-gg/quasar-test",
  "version": "0.1.0",
  "description": "Fixture-first tests for Solana programs built with Quasar",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./kit": {
      "types": "./dist/kit.d.ts",
      "default": "./dist/kit.js"
    },
    "./web3.js": {
      "types": "./dist/web3.d.ts",
      "default": "./dist/web3.js"
    }
  },
  "files": [
    "dist",
    "LICENSE-APACHE",
    "LICENSE-MIT",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit && tsc --noEmit -p tsconfig.tests.json",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "license": "Apache-2.0 OR MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blueshift-gg/quasar.git",
    "directory": "test/typescript"
  },
  "homepage": "https://quasar-lang.com",
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@blueshift-gg/quasar-svm": "^0.1.14",
    "@solana-program/token": "^0.15.0",
    "@solana/kit": "^7.0.0"
  },
  "peerDependencies": {
    "@solana/web3.js": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@solana/web3.js": {
      "optional": true
    }
  },
  "devDependencies": {
    "@solana/web3.js": "^3.0.0",
    "@types/node": "^22.13.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
