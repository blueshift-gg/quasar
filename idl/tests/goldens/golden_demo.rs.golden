//// errors.rs ////
#[derive(Debug, Clone, Copy, PartialEq, Eq)]
#[repr(u32)]
pub enum GoldenDemoError {
    Unauthorized = 6000,
}

impl GoldenDemoError {
    pub fn from_code(code: u32) -> Option<Self> {
        match code {
            6000 => Some(Self::Unauthorized),
            _ => None,
        }
    }

    pub fn message(&self) -> &'static str {
        match self {
            Self::Unauthorized => "caller is not the vault authority",
        }
    }
}

impl From<GoldenDemoError> for u32 {
    fn from(error: GoldenDemoError) -> Self {
        error as u32
    }
}

//// pda.rs ////
use solana_address::Address;

/// Seeds: [b"vault", authority]
pub fn find_vault_address(authority: &Address, program_id: &Address) -> (Address, u8) {
    Address::find_program_address(&[b"vault", authority.as_ref()], program_id)
}

